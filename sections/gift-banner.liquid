<style>

</style>
<section class="gift-banner" id="gift-banner-{{ section.id }}" >

{% comment %} Header section {% endcomment %}
    <header class="gift-banner__topbar">
        <button class="gift-banner__burger" type="button" aria-label="Open menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <a href="{{ section.settings.logo_link }}" class="gift-banner__logo">
            {% if section.settings.logo != blank %}
                <img src="{{ section.settings.logo |  image_url: width: 300 }}" alt="{{ section.settings.logo_text | escape }}" loading="eager" width="300" height="100" />
            {% else %}
                {{ section.settings.logo_text | escape }}
            {% endif %}
        </a>

        {% comment %} mobile whole slide block in from the left as a drawer {% endcomment %}
         <div class="gift-banner__menu" data-menu>

            <div class="gift-banner__menu-head">
                <button class="gift-banner__close" type="button" data-menu-close aria-label="Close menu">

                </button>
                <span class="gift-banner__menu-logo">{{ section.settings.logo_text | escape }}</span>
            </div>

            <p class="gift-banner__tagline">{{ section.settings.topbar_tagline | escape }}</p>

            <a href="{{ section.settings.topbar_button_link | default: '#' }}" class="gift-banner__pill gift-btn-anim">
                <span class="gift-btn-anim__label">{{ section.settings.topbar_button_text | escape }}</span>
                <svg class="gift-arrow"></svg>
            </a>

         </div>

         <div class="gift-banner__overlay" data-menu-overlay></div>
    </header>


    <div class="gift-banner__hero">
        {% if section.settings.hero_image != blank %}
           <img class="gift-banner__bg"
            src="{{ section.settings.background_image | image_url: width: 1920 }}"
            srcset="{{ section.settings.background_image |  image_url: width: 600 }} 600w, {{ section.settings.background_image |  image_url: width: 1200 }} 1200w, {{ section.settings.background_image |  image_url: width: 1920 }} 1920w"
            sizes="100vw"
            alt="{{ section.settings.heading | escape }}"
            loading="eager" width="1920" height="1080"
            fetchpriority="high"
           />
        {% endif %}

        <div class="gift-banner__content">
            {% if section.settings.heading != blank %}
                <h1 class="gift-banner__heading">{{ section.settings.heading | escape }}</h1>
            {% endif %}

            {% if section.settings.description != blank %}
                <div class="gift-banner__desc gift-banner__desc--desktop">{{ section.settings.description | escape }}</div>
            {% endif %}

            {% if section.settings.mobile_description != blank %}
                <div class="gift-banner__desc gift-banner__desc--mobile">{{ section.settings.mobile_description | escape }}</div>
            {% endif %}

            {% if section.settings.button_text != blank and section.settings.button_link != blank %}
                <a href="{{ section.settings.button_link | default: '#' }}" class="gift-banner__cta gift-btn-anim gift-btn-anim--dark">
                    <span class="gift-btn-anim__label">{{ section.settings.button_text | escape }}</span>
                </a>
            {% endif %}

        </div>
    </div>

</section>

{% schema %}
    {
        "name": "Gift Banner",
        "class": "gift-banner-section",
        "tag": "section",
        "settings": [
            { "type": "header", "content": "Top bar" },
            { "type": "image_picker", "id": "logo", "label": "Logo image (optional)" },
            { "type": "text", "id" : "logo_text", "label" : "Logo text (required)", "default" : "TISSO VISON" },
            { "type": "url", "id" : "logo_link", "label" : "Logo link (optional)", "default" : "/" },
            { "type": "text", "id": "topbar_tagline", "label": "Tagline", "default": "Find the ideal gift for your loved ones." },
            { "type": "text", "id": "topbar_button_text", "label": "Button text", "default": "CHOOSE GIFT" },
            { "type": "url", "id": "topbar_button_link", "label": "Button link" },

            { "type": "header", "content": "Hero Section" },
            { "type": "image_picker", "id": "background_image", "label": "Hero background image" },
            { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
            { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>" },
            { "type": "richtext", "id": "mobile_description", "label": "Mobile Description(shorter)", "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.</p>" },
            { "type": "text", "id": "button_text", "label": "Button text", "default": "SHOP NOW" },
            { "type": "url", "id":"button_link", "label": "Button link" },

            { "type": "header", "content": "Bottom Strip" },
            { "type": "text", "id": "strip_text", "label": "Bottom strip text", "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL" },

            {"type": "header", "content": "Appearance Settings"},
            {"type": "color", "id": "accent_color", "label": "Accent Color", "default": "#FFF544"}

        ],
        "presets": [
            {
                "name": "Gift Banner", "category": "Gift Page"
            }
        ]
    }
{% endschema %}